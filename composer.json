{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "joelbutcher/laravel-skeleton",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": [
        "laravel",
        "framework"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "brick/date-time": "^0.9.0",
        "gosuperscript/monads": "^1.1",
        "laravel/framework": "^13.0",
        "laravel/octane": "^2.17",
        "laravel/tinker": "^3.0",
        "php-standard-library/php-standard-library": "^6.1"
    },
    "require-dev": {
        "behat/behat": "^3.30",
        "carthage-software/mago": "^1.18",
        "fakerphp/faker": "^1.23",
        "infection/infection": "^0.32.6",
        "larastan/larastan": "^3.9",
        "laravel/boost": "^2.2",
        "laravel/pail": "^1.2.5",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "php-standard-library/phpstan-extension": "^2.1",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^12.0",
        "robiningelbrecht/phpunit-coverage-tools": "^1.10",
        "spatie/laravel-ray": "^1.43",
        "spatie/x-ray": "^1.2",
        "spaze/phpstan-disallowed-calls": "^4.10"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "npm install --ignore-scripts",
            "npm run build"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "@php artisan boost:update --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1 --timeout=0\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "format": "vendor/bin/mago fmt",
        "format:check": "vendor/bin/mago fmt --check",
        "lint": "vendor/bin/mago lint",
        "lint:fix": "vendor/bin/mago lint --fix --unsafe --format-after-fix",
        "test": [
            "@test:unit",
            "@test:types"
        ],
        "test:unit": "XDEBUG_MODE=coverage vendor/bin/phpunit",
        "test:types": "XDEBUG_MODE=off vendor/bin/phpstan analyse --memory-limit=512M",
        "test:mutation": "vendor/bin/infection --min-msi=100 --no-progress --threads=4",
        "test:features": "vendor/bin/behat --no-interaction --format=progress",
        "before-stopping": [
            "@test:unit",
            "@test:types",
            "@test:features",
            "@test:mutation",
            "@format",
            "@lint:fix"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "carthage-software/mago": true,
            "infection/extension-installer": true,
            "php-http/discovery": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
